{
    "manifest_version": 3,
    "name": "Neosrc GitHub integration",
    "version": "0.3.0",
    "description": "Neosrc GitHub integration",
    "host_permissions": ["https://github.com/*", "https://www.github.com/*"],
    "permissions": ["declarativeNetRequest", "storage"],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup/popup.html",
        "default_title": "Neosrc"
    },
    "icons": {
        "16": "icons/icon16.svg",
        "48": "icons/icon48.svg",
        "128": "icons/icon128.svg"
    },
    "content_scripts": [
        {
            "matches": [
                "https://github.com/*/*/pull/*",
                "https://github.com/*/*/pull/*/*",
                "https://github.com/*/*/pull/*/*/*"
            ],
            "js": ["content.js"]
        }
    ]
}

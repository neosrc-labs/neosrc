{
  "manifest_version": 3,
  "name": "GitHub PR Redirector",
  "version": "1.0",
  "description": "Redirects GitHub pull request comment tabs to localhost:3000.",
  "permissions": [
    "activeTab",
    "scripting",
    "webNavigation"
  ],
  "host_permissions": [
    "https://github.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["content.js"]
    }
  ]
}
